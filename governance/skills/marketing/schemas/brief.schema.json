{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://a-team.dev/schemas/marketing/brief.schema.json",
  "title": "Content Brief Schema",
  "description": "marketing-research Phase 5 산출물 스키마. marketing-generate가 --research 플래그로 받는 입력.",
  "type": "object",
  "required": [
    "title_options",
    "recommended_title",
    "meta_description",
    "target_reader",
    "unique_angle",
    "content_structure",
    "seo",
    "quality_bar",
    "cta_strategy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "title_options": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": { "type": "string", "minLength": 10, "maxLength": 80 }
    },
    "recommended_title": {
      "type": "string",
      "minLength": 10,
      "maxLength": 80
    },
    "meta_description": {
      "type": "string",
      "minLength": 100,
      "maxLength": 160
    },
    "target_reader": {
      "type": "object",
      "required": ["persona", "knows_going_in", "wants_to_know"],
      "properties": {
        "persona": { "type": "string" },
        "knows_going_in": { "type": "string" },
        "wants_to_know": { "type": "string" }
      }
    },
    "unique_angle": {
      "type": "string",
      "minLength": 30,
      "description": "What ONLY we can say that competitors can't"
    },
    "word_count_target": {
      "type": "integer",
      "minimum": 1000,
      "maximum": 8000
    },
    "content_structure": {
      "type": "object",
      "required": ["h1", "hook", "sections", "conclusion"],
      "properties": {
        "h1": { "type": "string" },
        "hook": {
          "type": "object",
          "required": ["strategy", "word_count"],
          "properties": {
            "strategy": {
              "type": "string",
              "enum": ["stat", "story", "question", "promise", "contrarian"]
            },
            "word_count": { "type": "integer", "minimum": 50, "maximum": 200 }
          }
        },
        "sections": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "required": ["h2", "word_count", "purpose", "key_points"],
            "properties": {
              "h2": { "type": "string" },
              "word_count": { "type": "integer", "minimum": 100 },
              "keyword": { "type": "string" },
              "purpose": { "type": "string" },
              "key_points": {
                "type": "array",
                "minItems": 2,
                "items": { "type": "string" }
              },
              "evidence_needed": {
                "type": "array",
                "items": { "type": "string" }
              },
              "human_insert": {
                "type": "string",
                "description": "Marker description if section needs personal voice"
              }
            }
          }
        },
        "faq": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["question", "source"],
            "properties": {
              "question": { "type": "string" },
              "source": {
                "type": "string",
                "enum": ["audience_research", "serp", "manual"]
              }
            }
          }
        },
        "conclusion": {
          "type": "object",
          "required": ["strategy", "word_count"],
          "properties": {
            "strategy": {
              "type": "string",
              "enum": ["forward-looking", "summary", "cta", "challenge"]
            },
            "word_count": { "type": "integer", "minimum": 50 }
          }
        }
      }
    },
    "seo": {
      "type": "object",
      "required": ["primary_keyword"],
      "properties": {
        "primary_keyword": { "type": "string" },
        "secondary_keywords": {
          "type": "array",
          "items": { "type": "string" }
        },
        "keyword_density_note": { "type": "string" },
        "schema_markup": {
          "type": "string",
          "enum": ["FAQ", "HowTo", "Article", "Product"]
        },
        "internal_links": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["anchor_text", "target_page"],
            "properties": {
              "anchor_text": { "type": "string" },
              "target_page": { "type": "string" }
            }
          }
        }
      }
    },
    "quality_bar": {
      "type": "object",
      "required": ["minimum_original_examples", "data_points_to_cite", "human_insert_sections"],
      "properties": {
        "minimum_original_examples": { "type": "integer", "minimum": 1 },
        "data_points_to_cite": { "type": "integer", "minimum": 1 },
        "human_insert_sections": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "cta_strategy": {
      "type": "object",
      "required": ["primary"],
      "properties": {
        "primary": { "type": "string" },
        "secondary": { "type": "string" },
        "email_capture_opportunity": { "type": "string" }
      }
    }
  }
}
