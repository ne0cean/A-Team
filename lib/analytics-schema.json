{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ne0cean/A-Team/lib/analytics-schema.json",
  "title": "A-Team Analytics Event",
  "description": "JSONL event schema for .context/analytics.jsonl. Single source of truth for all module-level telemetry. Phase 0 of team-roadmap.md.",
  "type": "object",
  "required": ["skill", "ts", "repo"],
  "properties": {
    "skill": {
      "type": "string",
      "description": "Originating skill/module/agent name. e.g. 'design-auditor', 'marketing-research', 'session', 'sleep-resume'."
    },
    "ts": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp."
    },
    "repo": {
      "type": "string",
      "description": "Repo slug (e.g. 'a-team', 'connectome'). Identifies which project generated the event."
    },
    "event": {
      "type": "string",
      "enum": [
        "hook_fire",
        "session_cost",
        "design_audit",
        "marketing_research",
        "marketing_generate",
        "marketing_repurpose",
        "marketing_publish",
        "marketing_analytics",
        "design_generate",
        "design_thumbnail",
        "design_brief",
        "intelligence_competitor_diff",
        "intelligence_persona_built",
        "intelligence_trend_signal",
        "bi_external_pull",
        "bi_insight_generated",
        "bi_anomaly_detected",
        "qa_run",
        "ralph_iteration",
        "sleep_resume_probe",
        "ops_pr_monitoring",
        "ops_cs_response"
      ],
      "description": "Event type. Phase 0-6 ordered. Add new types as Phase rolls forward."
    },

    "pattern": { "type": "string", "description": "Matched pattern for hook_fire events." },

    "totalCostUsd": { "type": "number", "minimum": 0, "description": "session_cost: USD spent in this session." },
    "callCount": { "type": "integer", "minimum": 0, "description": "session_cost: API call count." },
    "preCheckSkipRate": { "type": "number", "minimum": 0, "maximum": 1, "description": "session_cost: pre-check agent skip ratio." },
    "advisorCallAvg": { "type": "number", "description": "session_cost: avg advisor call latency or count." },
    "cacheHitRate": { "type": "number", "minimum": 0, "maximum": 1, "description": "session_cost: prompt cache hit ratio." },

    "designScore": { "type": "integer", "minimum": 0, "maximum": 100, "description": "design_audit: 0-100 quality score." },
    "designViolations": { "type": "integer", "minimum": 0, "description": "design_audit: total violation count." },
    "designA11yViolations": { "type": "integer", "minimum": 0, "description": "design_audit: a11y-only count." },
    "designAiSlopViolations": { "type": "integer", "minimum": 0, "description": "design_audit: ai_slop-only count." },
    "designTone": { "type": "string", "description": "design_audit: declared tone (brutalist | luxury | editorial-technical | ...)." },
    "designGateContext": { "type": "string", "enum": ["ship", "craft", "default"], "description": "design_audit: gate threshold context." },
    "designPassed": { "type": "boolean", "description": "design_audit: meetsThreshold() && a11y === 0." },

    "marketingTopic": { "type": "string", "description": "marketing_*: topic slug." },
    "marketingPlatform": { "type": "string", "description": "marketing_*: target platform (twitter | linkedin | instagram | tiktok | blog | email)." },
    "marketingMode": { "type": "string", "enum": ["blog-first", "social-first", "dry-run", "scheduled", "published"], "description": "marketing_*: mode/state." },
    "marketingArtifactPath": { "type": "string", "description": "marketing_*: produced artifact path (relative)." },
    "marketingHumanInsertCount": { "type": "integer", "minimum": 0, "description": "marketing_generate: [HUMAN INSERT] marker count." },
    "marketingPostizJobId": { "type": "string", "description": "marketing_publish: Postiz job_id (or 'dry-run-*' for dry-runs)." },
    "marketingImpressions": { "type": "integer", "minimum": 0, "description": "marketing_analytics: impressions count." },
    "marketingEngagements": { "type": "integer", "minimum": 0, "description": "marketing_analytics: engagements count." },
    "marketingConversionRate": { "type": "number", "minimum": 0, "maximum": 1, "description": "marketing_analytics: conversion ratio." },

    "intelligenceSource": { "type": "string", "description": "intelligence_*: data source (url, twitter handle, subreddit)." },
    "intelligenceSignalScore": { "type": "number", "minimum": 0, "maximum": 1, "description": "intelligence_trend_signal: 0-1 strength." },

    "biSourceCount": { "type": "integer", "minimum": 0, "description": "bi_external_pull: number of external sources pulled." },
    "biInsightCount": { "type": "integer", "minimum": 0, "description": "bi_insight_generated: distinct insights produced." },
    "biAnomalyMagnitude": { "type": "number", "description": "bi_anomaly_detected: standardized anomaly magnitude (z-score)." },

    "qaTestsTotal": { "type": "integer", "minimum": 0 },
    "qaTestsPassed": { "type": "integer", "minimum": 0 },
    "qaDurationMs": { "type": "integer", "minimum": 0 },

    "ralphIterationN": { "type": "integer", "minimum": 0 },
    "ralphCheckPassed": { "type": "boolean" },

    "sleepResumeAttempt": { "type": "integer", "minimum": 1 },
    "sleepResumeBackoffMs": { "type": "integer", "minimum": 0 },
    "sleepResumeProbePassed": { "type": "boolean" }
  },
  "additionalProperties": true
}
