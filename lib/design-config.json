{
  "version": 1,
  "name": "design-auditor",
  "failureThreshold": 3,
  "windowMs": 60000,
  "cooldownMs": 30000,
  "halfOpenProbes": 1,
  "countThreshold": 5,
  "windowCount": 10,
  "detectorConfig": {
    "enabled": true,
    "minScore": {
      "ship": 70,
      "craft": 85,
      "default": 60
    },
    "a11yNonNegotiable": true,
    "scoreWeights": {
      "a11y": 15,
      "ai_slop": 8,
      "readability": 5,
      "layout": 3,
      "polish": 5
    },
    "genericFonts": [
      "Inter",
      "Roboto",
      "Arial",
      "Helvetica Neue",
      "Space Grotesk"
    ],
    "genericCopyPatterns": [
      "Revolutionize",
      "Supercharge",
      "Unleash",
      "Effortlessly",
      "Seamless experience",
      "Transform your workflow",
      "10x your productivity",
      "lorem ipsum",
      "dolor sit amet"
    ],
    "purpleAccents": [
      "#7C3AED",
      "#8B5CF6",
      "#A78BFA",
      "#6D28D9",
      "#5B21B6"
    ],
    "gridMultiple": 8,
    "gridExceptions": [1, 2, 4, 8, 12, 16, 24, 32, 48, 64, 96, 128],
    "minTouchTarget": 44,
    "minBodyFontSize": 14,
    "minLineHeight": 1.4
  },
  "loadRouting": {
    "gate": "governance/design/gate.md",
    "toneFirst": "governance/design/tone-first.md",
    "variants": "governance/design/variants.md",
    "components": "governance/design/components.md",
    "antiPatterns": "governance/design/anti-patterns.md"
  }
}
