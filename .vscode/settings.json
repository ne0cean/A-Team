{
  "pasteImage.path": "${projectRoot}/cortex/attachments",
  "pasteImage.namePrefix": "${currentFileNameWithoutExt}-",
  "pasteImage.defaultName": "${datetime}",
  "pasteImage.insertPattern": "![${imageFileName}](../attachments/${imageFileName})",

  "files.exclude": {
    "cortex/.onenote-*": true
  },

  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": false
    }
  }
}
