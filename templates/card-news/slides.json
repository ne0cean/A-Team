{
  "hook": {
    "class": "slide slide-hook",
    "template": "<div class=\"title\">{{TITLE}}</div><div class=\"subtitle\">{{SUBTITLE}}</div>"
  },
  "content": {
    "class": "slide slide-content",
    "template": "<div class=\"number\">{{NUMBER}}</div><div class=\"heading\">{{HEADING}}</div><div class=\"body\">{{BODY}}</div>"
  },
  "cta": {
    "class": "slide slide-cta",
    "template": "<div class=\"message\">{{MESSAGE}}</div><div class=\"action\">{{ACTION_TEXT}}</div>"
  },
  "tones": {
    "editorial": { "bg": "#1a1a2e", "text": "#ffffff", "accent": "#4361ee" },
    "bold": { "bg": "#000000", "text": "#ffffff", "accent": "#ff6b6b" },
    "minimal": { "bg": "#fafafa", "text": "#1a1a1a", "accent": "#2d3436" },
    "playful": { "bg": "#fff5f5", "text": "#2d3436", "accent": "#e17055" }
  },
  "structure": [
    { "slide": 1, "type": "hook", "role": "주목 끄는 제목" },
    { "slide": 2, "type": "content", "role": "문제 제기 1" },
    { "slide": 3, "type": "content", "role": "문제 제기 2" },
    { "slide": 4, "type": "content", "role": "해결책 1" },
    { "slide": 5, "type": "content", "role": "해결책 2" },
    { "slide": 6, "type": "content", "role": "해결책 3" },
    { "slide": 7, "type": "content", "role": "요약" },
    { "slide": 8, "type": "cta", "role": "액션 유도" }
  ]
}
