{
  "name": "a-team",
  "version": "1.0.0",
  "description": "> ClawTeam(HKUDS) 분석 기반 + gstack 통합. > **에이전트가 망치지 않게 (Harness), 맥락을 잃지 않게 (Mirror), 할 일을 놓치지 않게 (TODO)**",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc --noEmit",
    "install-classical-tools": "bash scripts/install-classical-tools.sh",
    "install-classical-tools:with-sg": "bash scripts/install-classical-tools.sh --with-ast-grep",
    "bench": "node scripts/bench-runner.mjs --dry-run",
    "bench:baseline": "node scripts/bench-runner.mjs --tag v-baseline --runs 3 --dry-run",
    "bench:estimate": "node scripts/bench-wave1-candidate.mjs",
    "verify-g7": "node scripts/verify-g7.mjs",
    "research:weekly": "bash scripts/weekly-research.sh",
    "license:check": "license-checker-rseidelsohn --production --onlyAllow 'MIT;Apache-2.0;BSD-2-Clause;BSD-3-Clause;ISC;0BSD'",
    "license:report": "license-checker-rseidelsohn --production --json > coverage/licenses.json",
    "health": "node scripts/health-check.mjs",
    "health:alert": "node scripts/health-check.mjs --alert-only",
    "mutate": "npx stryker run",
    "mutate:changed": "npx stryker run --incremental"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ne0cean/A-Team.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/ne0cean/A-Team/issues"
  },
  "homepage": "https://github.com/ne0cean/A-Team#readme",
  "devDependencies": {
    "@fast-check/vitest": "^0.4.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.5",
    "archunit": "^2.3.0",
    "fast-check": "^4.8.0",
    "license-checker-rseidelsohn": "^4.4.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.91.1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
